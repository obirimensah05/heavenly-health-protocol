# Copy this template to ~/.config/heavenly/runtime.env and set mode 0600.
# Never commit the populated runtime file. Empty values disable optional modes.

# User-controlled Supabase storage. Keys are runtime-only.
SUPABASE_URL=
# Preferred: a PostgREST JWT whose `role` claim is heavenly_health_app, created
# by sql/003_least_privilege.sql. It reaches the two health tables and nothing
# else. Set this and leave the service-role key empty.
#   supabase gen bearer-jwt --role heavenly_health_app --valid-for 8760h
SUPABASE_HEALTH_ROLE_KEY=
# Required alongside it. Supabase validates `apikey` against the project's
# registered keys and reads the role from `Authorization`, so a minted role
# token cannot identify the project on its own. This key is public by design.
SUPABASE_PUBLISHABLE_KEY=
# Fallback only. Service-role bypasses RLS across the whole project, so a
# compromised MCP process would reach every table, not just health data.
SUPABASE_SERVICE_ROLE_KEY=
HEAVENLY_HEALTH_TABLE=heavenly_health_events
HEAVENLY_RAW_HEALTH_TABLE=heavenly_health_raw_events
HEAVENLY_ALLOWED_METRICS=steps,heart_rate,resting_heart_rate,heart_rate_variability,sleep_analysis,walking_running_distance,active_energy,body_mass,oxygen_saturation,respiratory_rate,vo2_max,stress_level,body_battery

# Optional implemented Health Auto Export delivery-table normalization.
HEAVENLY_APPLE_HEALTH_DELIVERY_TABLE=

# Optional private context relation. Set the whole group or leave it empty.
HEAVENLY_CONTEXT_TABLE=
HEAVENLY_CONTEXT_ID_COLUMN=
HEAVENLY_CONTEXT_TITLE_COLUMN=
HEAVENLY_CONTEXT_BODY_COLUMN=
HEAVENLY_CONTEXT_SEARCH_COLUMN=
HEAVENLY_CONTEXT_UPDATED_COLUMN=

# Optional Cloudflare Managed OAuth origin trust. These values come from the
# user's own Access application. Set the complete group or leave it empty.
HEAVENLY_CLOUDFLARE_TEAM_DOMAIN=
HEAVENLY_CLOUDFLARE_ACCESS_AUDIENCE=
HEAVENLY_CLOUDFLARE_ALLOWED_EMAILS=
HEAVENLY_MCP_PUBLIC_HOST=

# Optional listener override. Loopback is the safe default.
HEAVENLY_MCP_HOST=127.0.0.1
HEAVENLY_MCP_PORT=8791
